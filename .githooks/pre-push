#!/usr/bin/env bash
set -euo pipefail

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

echo -e "${YELLOW}[pre-push] Lancement des vérifications...${NC}"

# ── 1. go test ────────────────────────────────────────────────────────────────
echo -e "${YELLOW}[pre-push] go test ./...${NC}"
if ! go test ./...; then
  echo -e "${RED}[pre-push] ✗ Tests échoués — push annulé.${NC}"
  exit 1
fi
echo -e "${GREEN}[pre-push] ✓ Tests OK${NC}"

# ── 2. golangci-lint ──────────────────────────────────────────────────────────
if ! command -v golangci-lint &>/dev/null; then
  echo -e "${RED}[pre-push] golangci-lint introuvable. Installe-le : https://golangci-lint.run/usage/install/${NC}"
  exit 1
fi

echo -e "${YELLOW}[pre-push] golangci-lint run${NC}"
if ! golangci-lint run ./...; then
  echo -e "${RED}[pre-push] ✗ Lint échoué — push annulé.${NC}"
  exit 1
fi
echo -e "${GREEN}[pre-push] ✓ Lint OK${NC}"

echo -e "${GREEN}[pre-push] Toutes les vérifications passées — push autorisé.${NC}"
exit 0
